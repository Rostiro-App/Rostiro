# Rostiro OS — Environment Variables
# Copy to .env.local for local development. Never commit .env.local.

# ─── Supabase ──────────────────────────────────────────────────────────────────
# From: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # safe for client — used in browser
SUPABASE_SERVICE_ROLE_KEY=              # server-side only — NEVER expose to client

# ─── Yahoo Fantasy Sports API ──────────────────────────────────────────────────
# From: developer.yahoo.com → My Apps → create app
# Required scopes: fspt-r (read) + fspt-w (write)
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REDIRECT_URI=https://rostiro.com/api/auth/yahoo/callback
# Preview / staging:
# YAHOO_REDIRECT_URI=https://rostiro.vercel.app/api/auth/yahoo/callback

# ─── Anthropic / Claude API ────────────────────────────────────────────────────
# From: console.anthropic.com → API Keys
# Model: claude-sonnet-4-6 (used exclusively per PRD)
ANTHROPIC_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
# From: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=     # safe for client

# Stripe Price IDs — create in Stripe dashboard, paste here
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_COMMISSIONER_MONTHLY=
STRIPE_PRICE_COMMISSIONER_ANNUAL=
STRIPE_PRICE_INTELLIGENCE_ADDON_MONTHLY=
STRIPE_PRICE_INTELLIGENCE_ADDON_ANNUAL=

# ─── Stripe — T-85 pricing (Free / Pro / Season Pass / Founding 500) ──────────
# Create these 3 Prices in the Stripe Dashboard (test mode), paste IDs here.
# Distinct from the STRIPE_PRICE_*_MONTHLY/ANNUAL vars above, which are
# leftovers from the four-tier + Intelligence add-on model PRD v5 replaced.
STRIPE_PRICE_PRO=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_COMMISSIONER=

# ─── Encryption ────────────────────────────────────────────────────────────────
# AES-256 key for ESPN credentials + Yahoo tokens at rest.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── OneSignal (Web Push) ─────────────────────────────────────────────────────
# From: onesignal.com → your app → Settings → Keys & IDs
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
NEXT_PUBLIC_ONESIGNAL_APP_ID=           # safe for client — used in service worker

# ─── Resend (Email) ───────────────────────────────────────────────────────────
# From: resend.com → API Keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@rostiro.com

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://rostiro.com
# Local dev:
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cron ──────────────────────────────────────────────────────────────────────
# Authenticates Vercel Cron → /api/cron/* routes (Authorization: Bearer <value>).
# Vercel sets this header automatically when CRON_SECRET is set as an env var —
# just generate a value and add it in both places.
# Generate: openssl rand -hex 32
CRON_SECRET=
